# Supabase (public values are safe for the browser; never expose the service role key)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Apify (server-only)
APIFY_API_TOKEN=apify_api_YOUR_TOKEN
APIFY_LINKEDIN_ACTOR_ID=VhxlqQXRwhW8H5hNV

# Adjust this JSON to the chosen Actor's input schema. {{url}} is replaced server-side.
APIFY_LINKEDIN_INPUT_TEMPLATE={"username":"{{url}}","includeEmail":false}

# OpenAI (server-only). Used to combine LinkedIn data with meeting notes.
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini

# OpenRouter (server-only). Used by the dashboard AI assistant.
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY
OPENROUTER_MODEL=openai/gpt-oss-120b:free
